    receivers:
      kubeletstats:
        insecure_skip_verify: true
{% if splunk_observability.otel_collector.metrics_collection.etcd_metrics %}
      prometheus/etcd:
        config:
          scrape_configs:
            - job_name: "etcd"
              scheme: https
              metrics_path: "/metrics"
              scrape_interval: 10s
              static_configs:
                - targets:
                    - {% raw %}'${K8S_NODE_NAME}:9979'{% endraw %}
              tls_config:
                insecure_skip_verify: true
                ca_file: /etc/prometheus/secrets/etcd-metric-signer/tls.crt
                cert_file: /etc/prometheus/secrets/etcd-metric-client/tls.crt
                key_file: /etc/prometheus/secrets/etcd-metric-client/tls.key
{% endif %}
{% if splunk_observability.otel_collector.metrics_collection.pure_flash_arrays %}
{% for array in splunk_observability.otel_collector.metrics_collection.pure_flash_arrays %}
      prometheus/pure:
        config:
          scrape_configs:
            - job_name: 'pure_flash_arrays'
              metrics_path: '/metrics/array'
              scrape_interval: 60s
              scrape_timeout:  60s
              scheme: 'https'
              tls_config:
                insecure_skip_verify: true
              authorization:
                credentials: '{{ array.auth_token }}'
              params:
                namespace: ['{{ array.namespace }}']
              static_configs:
                - targets: 
                    - {{ array.endpoint }}
                  labels:
                    instance: {{ array.endpoint.split('.')[0] }}
                    env: 'production'
            - job_name: 'pure_flash_volumes'
              metrics_path: '/metrics/volumes'
              scrape_interval: 60s
              scrape_timeout:  60s
              scheme: 'https'
              tls_config:
                insecure_skip_verify: true
              authorization:
                credentials: '{{ array.auth_token }}'
              params:
                  namespace:
                    - '{{ array.namespace }}'
              static_configs:
                - targets: 
                    - {{ array.endpoint }}
                  labels:
                    instance: {{ array.endpoint.split('.')[0] }}
                    env: 'production'
{% endif %}
{% if splunk_observability.nexus is defined %}
      receiver_creator/nexus:
        # Name of the extensions to watch for endpoints to start and stop.
        watch_observers: 
          - k8s_observer
        receivers:
          prometheus/nexus:
            config:
              config:
                scrape_configs:
                  - job_name: nexus-metrics
                    metrics_path: /metrics
                    scrape_interval: 30s
                    scrape_timeout:  30s
                    static_configs:
                      - targets:
                          - '`endpoint`:9362'
            {% raw %}rule: type == "pod" && labels["app"] == "cisco-exporter"{% endraw %}
{% endif %}
{% raw %}            
      receiver_creator:
        # Name of the extensions to watch for endpoints to start and stop.
        watch_observers: 
          - k8s_observer
        receivers:
          prometheus/dcgm:
            config:
              config:
                scrape_configs:
                  - job_name: gpu-metrics
                    scrape_interval: 10s
                    static_configs:
                      - targets:
                          - '`endpoint`:9400'
            rule: type == "pod" && labels["app"] == "nvidia-dcgm-exporter"
          prometheus/kube-state-metrics:
            config:
              config:
                scrape_configs:
                  - authorization:
                      credentials_file: /var/run/secrets/kubernetes.io/serviceaccount/token
                      type: Bearer
                    job_name: kube-controller-manager
                    metric_relabel_configs:
                      - action: keep
                        regex: (kube_pod_start_time|kube_pod_status_scheduled_time|kube_pod_completion_time|kube_pod_status_initialized_time|kube_pod_status_ready_time|kube_pod_status_container_ready_time|kube_pod_status_unscheduled_time)(?:_sum|_count|_bucket)?
                        source_labels:
                          - __name__
                    scheme: https
                    tls_config:
                      insecure_skip_verify: true
                    static_configs:
                      - targets:
                          - '`endpoint`:8443'
            rule: type == "pod" && labels["app.kubernetes.io/name"] == "kube-state-metrics"
          prometheus/milvus:
            config:
              config:
                scrape_configs:
                  - job_name: milvus-metrics
                    static_configs:
                      - targets:
                          - '`endpoint`:9091'
            rule: type == "pod" && labels["app.kubernetes.io/name"] == "milvus"
{% endraw %}
{% if splunk_observability.otel_collector.metrics_collection.nvidia_gpu_metrics %}
{% raw %}
