distribution: openshift
readinessProbe:
  initialDelaySeconds: 180
livenessProbe:
  initialDelaySeconds: 180
operator:
  enabled: false
operatorcrds:
  installed: false
gateway:
  enabled: false
splunkObservability:
  profilingEnabled: true
agent:
  discovery:
    enabled: true
{% if splunk_observability.otel_collector.proxy is defined %}
  extraEnvs:
    - name: HTTP_PROXY
      value: "{{ splunk_observability.otel_collector.proxy.http_proxy }}"
    - name: HTTPS_PROXY
      value: "{{ splunk_observability.otel_collector.proxy.https_proxy }}"
    - name: NO_PROXY
      value: "{{ splunk_observability.otel_collector.proxy.no_proxy }}"
{% endif %}
{% if splunk_observability.otel_collector.metrics_collection.etcd_metrics %}
  extraVolumes:
    - name: etcd-certs-signer
      secret:
        secretName: splunk-monitoring-etcd-metrics-signer
    - name: etcd-certs-client
      secret:
        secretName: splunk-monitoring-etcd-metrics-client
  extraVolumeMounts:
    - name: etcd-certs-signer
      mountPath: /etc/prometheus/secrets/etcd-metric-signer
      readOnly: true
    - name: etcd-certs-client
      mountPath: /etc/prometheus/secrets/etcd-metric-client
      readOnly: true
{% endif %}
  resources:
    limits:
      cpu: 200m
      # This value is being used as a source for default memory_limiter processor configurations
      memory: 2000Mi
  config:
    exporters:
      debug:
        verbosity: detailed
      signalfx:
        send_otlp_histograms: true
{% raw %}
    processors:
      filter/health:
        error_mode: ignore
        traces:
          span:
            - |
              (
                IsMatch(name, ".*/v1/health/live.*") or
                IsMatch(name, ".*/v1/health/ready.*")
              )
{% endraw %}
      filter/metrics_to_be_included:
        metrics:
          # Include only metrics used in charts and detectors
          include:
            match_type: strict
            metric_names:
{% if splunk_observability.nexus is defined %}
              - cisco_collector_duration_seconds
              - cisco_interface_receive_broadcast
              - cisco_interface_receive_bytes
              - cisco_interface_receive_drops
              - cisco_interface_receive_errors
              - cisco_interface_receive_multicast
              - cisco_interface_transmit_bytes
              - cisco_interface_transmit_drops
              - cisco_interface_transmit_errors
              - cisco_interface_up
              - cisco_up
{% endif %}
{% if splunk_observability.otel_collector.metrics_collection.nvidia_gpu_metrics %}
              - DCGM_FI_DEV_ECC_SBE_VOL_TOTAL
              - DCGM_FI_DEV_ECC_DBE_VOL_TOTAL
              - DCGM_FI_DEV_ECC_SBE_AGG_TOTAL
              - DCGM_FI_DEV_ECC_DBE_AGG_TOTAL
              - DCGM_FI_DEV_ECC_SBE_VOL_L
              - DCGM_FI_DEV_ECC_DBE_VOL_L
              - DCGM_FI_DEV_ECC_SBE_VOL_L
