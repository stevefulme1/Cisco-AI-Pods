---
description: "{{ item.1.description | default('') }}"
enable_ssh: "{{ item.1.enabled | default(True) }}"
name: "{{ policy_name_prefix.ssh | default(policy_name_prefix.default | default('')) ~ item.1.name ~ policy_name_suffix.ssh | default(policy_name_suffix.default | default('')) }}"
organization: "{{ item.0.key }}"
ssh_port: "{{ item.1.ssh_port | default(22) }}"
ssh_timeout: "{{ item.1.ssh_timeout | default(1800) }}"
