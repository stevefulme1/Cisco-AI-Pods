---
description: "{{ item.1.description | default('') }}"
enable_override: "{{ item.1.allow_override | default(False) }}"
eth_adapter_policy_name: "{{ item.1.ethernet_adapter_policy | default('') }}"
eth_qos_policy_name: "{{ item.1.ethernet_qos_policy | default('') }}"
fabric_eth_network_control_policy_name: "{{ item.1.ethernet_network_control_policy | default('') }}"
fabric_eth_network_group_policy_name: "{{ item.1.ethernet_network_group_policies[0] if (item.1.ethernet_network_group_policies is defined and item.1.ethernet_network_group_policies | length > 0) else omit }}"
failover_enabled: "{{ item.1.enable_failover | default(False) }}"
{% if item.1.iscsi_boot_policy is defined %}
iscsi_boot_policy_name: "{{ item.1.iscsi_boot_policy }}"
{% endif %}
mac_pool_name: "{{ item.1.mac_address_pool | default('') }}"
name: "{{ policy_name_prefix.vnic_template | default(policy_name_prefix.default | default('')) ~ item.1.name ~ policy_name_suffix.vnic_template | default(policy_name_suffix.default | default('')) }}"
organization: "{{ item.0.key }}"
switch_id: "{{ item.1.placement_switch_id | default('A') }}"
{% if item.1.sriov is defined and item.1.sriov.enabled | default(False) %}
connection_type: "sriov"
sriov_settings:
  comp_count_per_vf: "{{ item.1.sriov.completion_queue_count_per_vf | default(5) }}"
  enabled: true
  int_count_per_vf: "{{ item.1.sriov.interrupt_count_per_vf | default(8) }}"
  rx_count_per_vf: "{{ item.1.sriov.receive_queue_count_per_vf | default(4) }}"
  tx_count_per_vf: "{{ item.1.sriov.transmit_queue_count_per_vf | default(1) }}"
  vf_count: "{{ item.1.sriov.number_of_vfs | default(64) }}"
{% elif item.1.usnic is defined %}
connection_type: "usnic"
usnic_settings:
  cos: "{{ item.1.usnic.class_of_service | default(5) }}"
  count: "{{ item.1.usnic.number_of_usnics | default(0) }}"
  usnic_adapter_policy_name: "{{ item.1.usnic.usnic_adapter_policy }}"
{% elif item.1.vmq is defined %}
connection_type: "vmq"
vmq_settings:
  enabled: "{{ item.1.vmq.enabled | default(True) }}"
  multi_queue_support: "{{ item.1.vmq.enable_virtual_machine_multi_queue | default(False) }}"
  num_interrupts: "{{ item.1.vmq.number_of_interrupts | default(16) }}"
  num_vmqs: "{{ item.1.vmq.number_of_virtual_machine_queues | default(4) }}"
{% endif %}
