---
{% set _local_user = item.1 | merge_schema_defaults(intersight_schema, 'intersight.local_user') %}
{% set local_user_vars = vars | combine(_local_user._resolved_sensitive_vars | default({})) %}
{% set _pp = item.1.password_properties | default({}) %}
always_update_password: "{{ _pp.always_send_user_password | default(False) }}"
description: "{{ item.1.description | default('') }}"
enable_password_expiry: "{{ _pp.enable_password_expiry | default(False) }}"
enforce_strong_password: "{{ _pp.enforce_strong_password | default(True) }}"
name: "{{ policy_name_prefix.local_user | default(policy_name_prefix.default | default('')) ~ item.1.name ~ policy_name_suffix.local_user | default(policy_name_suffix.default | default('')) }}"
organization: "{{ item.0.key }}"
password_history: "{{ _pp.password_history | default(5) }}"
{% if item.1.users is defined %}
local_users:
{% for user in item.1.users %}
  - enable: "{{ user.enabled | default(True) }}"
    password: "{{ local_user_vars['local_user_password_' ~ user.password] }}"
    role: "{{ user.role | default('readonly') }}"
    username: "{{ user.username }}"
{% endfor %}
{% endif %}
