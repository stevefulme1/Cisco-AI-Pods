---
{{
  item.1
  | merge_schema_defaults(intersight_schema, 'intersight.system_qos')
  | to_module_params('intersight_system_qos_policy')
  | combine({
      'description': item.1.description | default(omit),
      'name': policy_name_prefix.system_qos | default(policy_name_prefix.default | default(''))
               ~ item.1.name
               ~ policy_name_suffix.system_qos | default(policy_name_suffix.default | default('')),
      'organization': item.0.key
    })
}}
