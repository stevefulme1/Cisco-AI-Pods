---
cdp_enabled: "{{ item.1.cdp_enable | default(False) }}"
description: "{{ item.1.description | default(omit) }}"
forge_mac: "{{ item.1.forge_mac | default('allow') }}"
lldp_receive_enabled: "{{ item.1.lldp_enable_receive | default(False) }}"
lldp_transmit_enabled: "{{ item.1.lldp_enable_transmit | default(False) }}"
mac_registration_mode: "{{ item.1.mac_registration_mode | default('nativeVlanOnly') }}"
name: "{{ policy_name_prefix.ethernet_network_control | default(policy_name_prefix.default | default('')) ~ item.1.name ~ policy_name_suffix.ethernet_network_control | default(policy_name_suffix.default | default('')) }}"
organization: "{{ item.0.key }}"
uplink_fail_action: "{{ item.1.action_on_uplink_fail | default('linkDown') }}"
