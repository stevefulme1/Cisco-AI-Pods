---
{% set _ipmi = item.1 | merge_schema_defaults(intersight_schema, 'intersight.ipmi_over_lan') %}
{% set ipmi_vars = vars | combine(_ipmi._resolved_sensitive_vars | default({})) %}
description: "{{ item.1.description | default('') }}"
enabled: "{{ item.1.enabled | default(True) }}"
encryption_key: "{{ ipmi_vars['ipmi_key_' ~ item.1.encryption_key] if item.1.encryption_key | default(0) | int > 0 else '00' }}"
name: "{{ policy_name_prefix.ipmi_over_lan | default(policy_name_prefix.default | default('')) ~ item.1.name ~ policy_name_suffix.ipmi_over_lan | default(policy_name_suffix.default | default('')) }}"
organization: "{{ item.0.key }}"
privilege: "{{ item.1.privilege | default('admin') }}"
