apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: node-feature-discovery-operator
  namespace: openshift-gitops
spec:
  project: default
  source:
    repoURL: '{{ argocd.gitops_repo_url }}'
    targetRevision: HEAD
    path: olm-catalog/node-feature-discovery-operator
  destination:
    server: 'https://kubernetes.default.svc'
    namespace: openshift-nfd
  syncPolicy:
    automated:
      prune: {{ argocd.prune }}
      selfHeal: {{ argocd.self_heal }}
    syncOptions:
      - CreateNamespace=true
      - SkipDryRunOnMissingResource=true # Important: The NFD CRD won't exist during the first dry-run