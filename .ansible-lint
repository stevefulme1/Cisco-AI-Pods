---
# Ansible-lint configuration for cisco.ai_pods collection
offline: true

skip_list:
  # kubernetes.core.all module_defaults is valid but ansible-lint
  # doesn't recognize it as a valid action group
  - fqcn[action-core]
  - args[module]
  - name[missing]
  - yaml[truthy]
  - yaml[line-length]

# Exclude Helm templates (Go templating, not valid Ansible YAML)
exclude_paths:
  - openshift/openshift-gitops/helm/
  - best_practices/
  - images/
  - netapp/
  - .git/
  - '*.tar.gz'
  - dump_model.py
  - model_structure.json

# These are standalone scripts, not Ansible modules
mock_modules:
  - kubernetes.core.k8s
  - kubernetes.core.k8s_info
  - kubernetes.core.helm
  - kubernetes.core.helm_repository

# Warn don't error for known issues
warn_list:
  - experimental
  - role-name
